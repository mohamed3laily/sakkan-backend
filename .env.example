# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=

# JWT (users)
JWT_SECRET=
JWT_EXPIRES_IN=30m

# JWT (admins) — use a separate secret in production
ADMIN_JWT_SECRET=
ADMIN_JWT_EXPIRES_IN=7d
ADMIN_REGISTRATION_TOKEN=

# Redis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# AWS S3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# SMS (Torvo)
TORVO_SMS_API_KEY=
TORVO_SMS_REQUEST_TIMEOUT_MS=20000

# Firebase FCM
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Paymob
# Card and Wallet are TWO SEPARATE Payment Integrations in the Paymob dashboard,
# each with its own DISTINCT integration ID. They must NOT be the same value, or
# the unified checkout will only show one method.
PAYMOB_INTEGRATION_ID=                  # Card (UIG) — e.g. 5723501
PAYMOB_WALLET_INTEGRATION_ID=           # Mobile wallet (VPC) — MUST differ from card, e.g. 5723500
PAYMOB_SECRET_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_PUBLIC_KEY=
PAYMOB_ACCEPT_HOST=https://accept.paymob.com

# Apple In-App Purchase
APPLE_BUNDLE_ID=com.sakanapp.ios
APPLE_APP_STORE_CONNECT_KEY_ID=
APPLE_APP_STORE_CONNECT_ISSUER_ID=
APPLE_APP_STORE_CONNECT_PRIVATE_KEY=   # ES256 PEM key from App Store Connect
APPLE_IAP_SANDBOX=true                 # set to false in production
