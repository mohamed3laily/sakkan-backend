# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=

# JWT (users)
JWT_SECRET=
JWT_EXPIRES_IN=30d

# JWT (admins) — use a separate secret in production
ADMIN_JWT_SECRET=
ADMIN_JWT_EXPIRES_IN=7d
ADMIN_REGISTRATION_TOKEN=

# CORS — comma-separated allowed origins (required in production)
CORS_ORIGINS=

# Redis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# AWS S3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# SMS, Firebase, Paymob — add your existing env vars here
